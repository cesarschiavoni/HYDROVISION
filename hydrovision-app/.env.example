# HydroVision AG — Variables de entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el .env con secretos reales.

# ── Base de datos ─────────────────────────────────────────────────────────────
# Producción: PostgreSQL
DATABASE_URL=postgresql://hydrovision:CAMBIAR_PASSWORD@db:5432/hydrovision
# Desarrollo local (SQLite):
# DATABASE_URL=sqlite:///./hydrovision.db

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Clave HMAC-SHA256 compartida con los nodos de campo para autenticar payloads.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=CAMBIAR_POR_CLAVE_SEGURA

# ── PostgreSQL (usado por docker-compose) ─────────────────────────────────────
DB_PASSWORD=CAMBIAR_PASSWORD

# ── Feature flags ─────────────────────────────────────────────────────────────
# Habilitar endpoints /api/simulate/* (solo desarrollo/demo, deshabilitar en prod)
SIMULATION_MODE=false
